<Window x:Class="LinearListApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:LinearListApp.ViewModels"
        Title="Лабораторная работа: Линейный список" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">
    
    <!-- Подключение ViewModel -->
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть: Управление -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Новый элемент:" Margin="0,0,0,5" />
            <TextBox Text="{Binding NewItemText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="2"/>
            
            <Button Content="Добавить" Command="{Binding AddCommand}" Margin="0,0,0,10" Padding="5"/>
            <Button Content="Удалить текущий" Command="{Binding RemoveCommand}" Margin="0,0,0,10" Padding="5"/>
            <Button Content="Следующий элемент" Command="{Binding MoveNextCommand}" Margin="0,0,0,10" Padding="5"/>
            <Button Content="В начало списка" Command="{Binding MoveToBeginningCommand}" Margin="0,0,0,10" Padding="5"/>
        </StackPanel>

        <!-- Правая часть: Отображение данных и состояний -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Статистика -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10" Background="#F0F0F0">
                <StackPanel>
                    <TextBlock Text="Состояние списка:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Количество элементов: "/>
                        <TextBlock Text="{Binding ElementsCount}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Список пуст: "/>
                        <TextBlock Text="{Binding IsEmptyStatus}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Текущий элемент: "/>
                        <TextBlock Text="{Binding CurrentElement}" FontWeight="Bold" Foreground="Blue"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Визуальное отображение списка -->
            <GroupBox Grid.Row="1" Header="Элементы списка">
                <!-- IsSynchronizedWithCurrentItem отключен, так как мы управляем выделением из нашей Модели -->
                <ListBox ItemsSource="{Binding Elements}" 
                         SelectedIndex="{Binding SelectedIndex, Mode=OneWay}" 
                         IsHitTestVisible="False" 
                         Focusable="False">
                    <!-- IsHitTestVisible="False" запрещает пользователю кликать мышкой по списку, 
                         вынуждая использовать только кнопки (как требуется в ТЗ для линейного списка) -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="LightBlue"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</Window>